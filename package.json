{
  "name": "@gittan/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BloomerAB/gittan-runner.git"
  },
  "dependencies": {
    "@gittan/types": "link:../types",
    "nats": "^2.29.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1"
}
